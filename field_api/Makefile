# Makefile for field_api
# Compiler and flags can be overridden on the command line, e.g.:
#   make FC=nvfortran FFLAGS="-O3"

# Compiler (matches the build directory configuration)
FC := pgf90

# Flags (matches the build directory configuration)
#   - toolchain base flags: -fpic -Mframe -Mbyteswapio -Mrecursive -Kieee -Mdaz -Mbackslash -Mlarge_arrays -Mstack_arrays -traceback
#   - RelWithDebInfo flags: -O2 -gopt
#   - OpenMP flags: -mp
FFLAGS := -fpic -Mframe -Mbyteswapio -Mrecursive -Kieee -Mdaz -Mbackslash -Mlarge_arrays -Mstack_arrays -traceback -O1 -gopt -mp

# Source files
SRCS := $(wildcard *.F90)

# Library sources (everything except master.F90)
LIB_SRCS := $(filter-out master.F90,$(SRCS))
LIB_OBJS := $(LIB_SRCS:.F90=.o)

# Executable
EXE := master.x
EXE_SRC := master.F90
EXE_OBJ := master.o

# Library
LIB := libfield_api.so

# Default target
.PHONY: all clean
all: $(LIB) $(EXE)

# Shared library
$(LIB): $(LIB_OBJS)
	$(FC) -shared -o $@ $(LIB_OBJS)

# Executable (link against shared lib, rpath=current dir so it runs without LD_LIBRARY_PATH)
$(EXE): $(EXE_OBJ) $(LIB)
	$(FC) $(FFLAGS) -Wl,-rpath,'$$ORIGIN' -o $@ $(EXE_OBJ) $(LIB)

# Generic compilation rule
%.o: %.F90
	$(FC) $(FFLAGS) -c $< -o $@

# Module dependencies (generated by parsing USE statements)
# Files with no external module dependencies simply rely on the %.o: %.F90 pattern rule

# Basic module dependencies
field_basic_module.o: parkind1.o

